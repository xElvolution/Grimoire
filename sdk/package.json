  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "0g",
    "zerog",
    "ai-agents",
    "agent-economy",
    "skills",
    "royalties",
    "tee",
    "verifiable-ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
